    <select id="queryByIdAndName" parameterType="com.itheima.entity.Book" resultType="com.itheima.entity.Book">
        SELECT * FROM book
        <trim prefix="WHERE" prefixOverrides="AND">
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="name != null and name !=''">
                AND name = #{name}
            </if>
        </trim>
    </select>

    <select id="findBooksWithSort" parameterType="string" resultType="com.itheima.entity.Book">
        SELECT * FROM book
        ORDER BY
        <choose>
            <when test="sortType == 'name'">
                name
            </when>
            <when test="sortType == 'price'">
                price
            </when>
            <otherwise>
                id
            </otherwise>
        </choose>
    </select>
    <select id="findBooksByIds"  resultType="com.itheima.entity.Book">
        SELECT * FROM book  WHERE id IN
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
    <insert id="batchInsertBooks" parameterType="java.util.List">
        INSERT INTO book (id, name, price) VALUES
        <foreach  collection="list" item="book" separator=",">
            (#{book.id}, #{book.name}, #{book.price})
        </foreach>
    </insert>
<!---->
    <select id="queryByConditions" parameterType="map" resultType="com.itheima.entity.Book">
        SELECT * FROM book
        WHERE 1 = 1
        <foreach item="item" index="key"  collection="conditions" open="AND (" separator="OR" close=")">
            ${key} = #{item}
        </foreach>
    </select>
<update id="updateBook" parameterType="com.itheima.entity.Book">
    UPDATE book
    <set>
        <if test="name != null and name !=''">
            name = #{name},
        </if>
        <if test="price != null">
            price = #{price},
        </if>
    </set>
    WHERE id = #{id}
</update>

</mapper>