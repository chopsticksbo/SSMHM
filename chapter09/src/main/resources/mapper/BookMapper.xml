        <select id="queryByIdAndName"
                parameterType="com.itheima.entity.Book"
                resultType="com.itheima.entity.Book">
            <!-- 根据id和name查询图书 -->
            select * from book where 1=1
            <!-- 如果id不为空，添加id条件 -->
            <if test="id != null">
                and id = #{id}
            </if>
            <!-- 如果name不为空，添加name条件 -->
            <if test="name != null and name != ''">
                and name = #{name}
            </if>
        </select>

